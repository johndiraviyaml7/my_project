# QuantixMed DICOM Frontend — environment variables
# Copy to .env and adjust for your setup

# Spring Boot backend URL
VITE_API_URL=http://localhost:8080

# OHIF Viewer URL (where you run OHIF)
VITE_OHIF_URL=http://localhost:3000

# DICOMweb root — Spring Boot proxies this to Orthanc
# OHIF uses this to fetch DICOM data
VITE_WADO_ROOT=http://localhost:8080/orthanc/dicom-web
